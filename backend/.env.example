# Copy this file to .env and fill in your keys
# Never commit .env to git!

# LLM - pick one (or both)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here        # optional

# Web search
TAVILY_API_KEY=your_tavily_key_here        # free at tavily.com

# App settings
LLM_PROVIDER=anthropic                     # "anthropic" or "openai"
LLM_MODEL=claude-sonnet-4-6               # or gpt-4o
EMBEDDING_MODEL=all-MiniLM-L6-v2          # free local model, no API needed
CHROMA_DB_PATH=./chroma_db                # where vector DB files are stored
MAX_CHUNK_SIZE=500                         # characters per text chunk
CHUNK_OVERLAP=50                           # overlap between chunks
TOP_K_RESULTS=5                            # how many chunks to retrieve per query
